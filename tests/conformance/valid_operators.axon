(* Edge cases for operators and expressions *)

(* Sequence operator *)
INF(@a>@b): x -> y -> z

(* Causal chain — right associative *)
INF(@a>@b): alert <- high-cpu <- spike

(* Parallel composition *)
REQ(@a>@b): task-1 & task-2 & task-3

(* Disjunction *)
INF(@a>@b): option-a | option-b

(* Comparisons *)
INF(@a>@b): x > 10
INF(@a>@b): x < 100
INF(@a>@b): x >= 10
INF(@a>@b): x <= 100
INF(@a>@b): x != y
INF(@a>@b): x = y

(* Range *)
INF(@a>@b): 1..100

(* Approximate *)
INF(@a>@b): ~42

(* Nested message *)
DEL(@ceo>@vp): REQ(*>@team): complete(#project-x)

(* Wildcard endpoint *)
CMD(*>@all): sync()

(* Agent list endpoint *)
REQ(@a>[@b, @c, @d]): broadcast("hello")

(* Nested comments *)
(* outer (* inner *) still outer *)
INF(@a>@b): "after nested comment"

(* Tagged record *)
INF(@a>@b): #task{id:"t-1", status:#done}

(* Extension performative *)
X.trade.BID(@buyer>@exchange): {symbol:"AAPL", qty:100}

(* Profile extension metadata keys *)
[id:"m1", %%:1, txn_id:"tx-42"]
PRO(@a>@b): {action:#debit}

(* Mixed named and positional args *)
INF(@a>@b): func(1, name:"val", 3)

(* Arithmetic: addition *)
INF(@a>@b): {total: price + tax}

(* Arithmetic: subtraction *)
INF(@a>@b): {remaining: balance - amount}

(* Arithmetic: multiplication *)
INF(@a>@b): {cost: price * qty}

(* Arithmetic: division *)
INF(@a>@b): {avg: total / count}

(* Arithmetic: compound expression *)
INF(@a>@b): {total: price * qty + tax}

(* Arithmetic: precedence — mul binds tighter than add *)
INF(@a>@b): a + b * c

(* Arithmetic: parenthesized override *)
INF(@a>@b): (a + b) * c

(* Arithmetic: chained operations *)
INF(@a>@b): a + b - c + d

(* Arithmetic in comparison *)
INF(@a>@b): x + y > threshold

(* Arithmetic in function args *)
INF(@a>@b): scale(base * factor, offset + 1)

(* Negation prefix ! *)
INF(@a>@b): !ready

(* Negation in boolean expression *)
INF(@a>@b): !ready & !done

(* Unary minus *)
INF(@a>@b): {delta: -5}

(* Unary minus on identifier *)
INF(@a>@b): {neg: -x}

(* Unary minus in function call *)
INF(@a>@b): adjust(-5, -offset)

(* Double-equals alias *)
INF(@a>@b): status == #active

(* Double-equals in comparison *)
INF(@a>@b): count == 0

(* Arithmetic in sequence *)
INF(@a>@b): compute(x + y) -> store($result)

(* Arithmetic in causal chain *)
INF(@a>@b): {over: T} <- usage > limit * 1.5
